+// TestLoadStateReseedsOldRevision verifies the one-time defaults re-seed: a
+// persisted config that predates saneDefaultsRevision (no defaults_revision key)
+// has ONLY its Grade/Rarity/Vendor sections overwritten with the current sane
+// defaults on load, while every other operator setting is preserved, the
+// revision is bumped, and the migrated state is persisted to disk.
+func TestLoadStateReseedsOldRevision(t *testing.T) {
+	dir := t.TempDir()
+	path := filepath.Join(dir, "state.json")
+
+	// Simulate a pre-upgrade state file: real operator content, stale pricing
+	// multipliers, and NO defaults_revision field (so it decodes as 0).
+	content := `{"buy_interval":"7m0s","list_interval":"45m0s","buy_threshold":1.2,` +
+		`"max_buys":99,"listings_per_grade":4,"enabled":true,` +
+		`"grade_multipliers":[1,1,1.25,1.5,1.65,1.5],` +
+		`"rarity_multipliers":{"common":5,"rare":5,"unique":5,"memento":5},` +
+		`"vendor_multipliers":{"common":5,"rare":5,"unique":5,"memento":5},` +
+		`"disabled_items":["item.keepme"]}`
+	if err := os.WriteFile(path, []byte(content), 0o600); err != nil {
+		t.Fatalf("WriteFile: %v", err)
+	}
+
+	got, err := LoadState(path)
+	if err != nil {
+		t.Fatalf("LoadState: %v", err)
+	}
+
+	def := defaultConfig()
+	// Pricing sections must be re-seeded to the current defaults.
+	if got.GradeMultipliers != def.GradeMultipliers {
+		t.Errorf("GradeMultipliers not re-seeded: got %v want %v", got.GradeMultipliers, def.GradeMultipliers)
+	}
+	for k, want := range def.RarityMultipliers {
+		if got.RarityMultipliers[k] != want {
+			t.Errorf("RarityMultipliers[%q] not re-seeded: got %v want %v", k, got.RarityMultipliers[k], want)
+		}
+	}
+	for k, want := range def.VendorMultipliers {
+		if got.VendorMultipliers[k] != want {
+			t.Errorf("VendorMultipliers[%q] not re-seeded: got %v want %v", k, got.VendorMultipliers[k], want)
+		}
+	}
+	// Revision bumped.
+	if got.DefaultsRevision != saneDefaultsRevision {
+		t.Errorf("DefaultsRevision: got %d want %d", got.DefaultsRevision, saneDefaultsRevision)
+	}
+	// Everything else preserved.
+	if got.MaxBuys != 99 || got.ListingsPerGrade != 4 || got.BuyThreshold != 1.2 {
+		t.Errorf("non-pricing fields clobbered: %+v", got)
+	}
+	if got.BuyInterval != 7*time.Minute || got.ListInterval != 45*time.Minute {
+		t.Errorf("intervals clobbered: buy=%v list=%v", got.BuyInterval, got.ListInterval)
+	}
+	if len(got.DisabledItems) != 1 || got.DisabledItems[0] != "item.keepme" {
+		t.Errorf("DisabledItems clobbered: %v", got.DisabledItems)
+	}
+
+	// The migration must persist: a second load sees revision already current
+	// and does NOT re-seed, so a subsequent operator override sticks.
+	reloaded, err := LoadState(path)
+	if err != nil {
+		t.Fatalf("LoadState (reload): %v", err)
+	}
+	if reloaded.DefaultsRevision != saneDefaultsRevision {
+		t.Errorf("persisted revision not current on reload: %d", reloaded.DefaultsRevision)
+	}
+
+	// Operator override after migration must survive the next load.
+	override := reloaded
+	override.GradeMultipliers = [6]float64{2, 2, 2, 2, 2, 2}
+	if err := SaveState(path, override); err != nil {
+		t.Fatalf("SaveState override: %v", err)
+	}
+	final, err := LoadState(path)
+	if err != nil {
+		t.Fatalf("LoadState (final): %v", err)
+	}
+	if final.GradeMultipliers != override.GradeMultipliers {
+		t.Errorf("operator override re-seeded away: got %v want %v", final.GradeMultipliers, override.GradeMultipliers)
+	}
+}
