# User-generated config (contains local paths — never commit)
dune-server.config

# Logs
*.log
.logs/

# Local SSH keys — never commit
sshKey
sshKey.pub
*.pem
*.key

# Local environment overrides
.env
.env.*
!.env.example

# Windows
Thumbs.db
desktop.ini

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Session / scratch
scratch/
tmp/

# Desktop app build artifacts (built locally before each release)
app/build/output/
app/installer/output/

# Linux .deb build output (built locally / in CI)
packaging/linux/output/

# Pre-redaction screenshot originals — contain real PII, never commit
docs/img/_originals/

# OneDrive cloud-sync leftovers — corrupt dehydrated placeholders that also
# break ripgrep (os error 383). Never commit.
*.todelete.gone~*
*~RF*.TMP

testResults.xml

