---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import Screenshot from "../components/Screenshot.astro";

const base = import.meta.env.BASE_URL;

const sections = [
  {
    id: "health",
    title: "Server Health",
    img: "server-health.png",
    body: "Default landing page. Combined battlegroup + VM state, live TCP port verdicts, per-pod game-server status, active spice-field counts pulled live from Postgres with tiered colours and at-cap highlighting, public port checks with provider fallback, and one-click log exports. BG state reads a green 'Healthy' while the operator is healthy or reconciling (its normal steady state), with a per-visit toggle to reveal the raw battlegroup status output.",
  },
  {
    id: "commands",
    title: "Commands",
    img: "commands.png",
    body: "Quick-action cards grouped by VM, Battlegroup, and Tools. Each card knows whether it runs in-app or in a popup, self-disables with a hint when it doesn't apply, and is drag-reorderable — the layout persists across launches.",
  },
  {
    id: "gameconfig",
    title: "Game Config",
    img: "game-config.png",
    body: "Grouped editor for UserGame.ini and UserEngine.ini with every setting labelled and typed. It reads the live INIs on load and shows your real values wherever they live in the file (no more phantom 'default' readings), then writes changes into a DST-managed block — guaranteeing each setting lives in exactly one section so toggles actually take effect. Sections cover Survival, Hydration, Storm Cycle, Landsraad, Loot & Death, Encounters, Spice, Sandworm and more — including the Landsraad settings Funcom packs into a single nested struct, edited in place. Every field has a one-click Default that *removes* the override from the INI, and client-applied settings show an Add / Update / Remove preview before you mirror them to your own game. An *All default settings* browser reads the live DefaultGame.ini / DefaultEngine.ini straight from the battlegroup. Backups are one click away — make a restore point when you want one, then multi-select and delete old snapshots from the View backups dialog.",
  },
  {
    id: "gameplay",
    title: "Gameplay Admin",
    img: "gameplay-admin.png",
    body: "the Gameplay Admin portal, rebuilt natively inside DST as a complete in-tree port (54 player-management endpoints, RMQ-backed online command channel, 28-action bucketed Actions panel). Market / Exchange and Market Bot tabs read your live game Postgres directly (and fall back to a realistic demo dataset when the battlegroup is offline). Duke — the native bot — both buys player listings and lists its own NPC stock under one of two pricing modes you toggle from the header: **Sane** (tier × category × rarity × vendor × grade, 100,000 Solari hard cap — the default) or **Upstream** Funcom-style (uncapped tier tables, vendor × rarity-mult, grade scaling — flip-on wipes Duke's listings so the new prices repopulate cleanly). Per-template overrides win in either mode, and **Seed market** bulk-lists every catalogued template across all six quality grades in one shot. **Clear listings** wipes Duke and any leftover Revy rows from the old external Go market-bot in a single sweep. The Players tab adds a Hide GM toggle, an inlined Items action group inside Inventory, and three ways to deselect a player — Bases, Storage, and Blueprints round out the toolset.     A shared admin-messaging surface (server broadcast, timed shutdown notice, and per-player whisper) sits at the top of the Gameplay overview and on its own Broadcasts page, inventory rows show live current / max durability colour-tiered by wear, and a Restore Destroyed Items action brings completely-dead gear back from zero durability alongside the regular Repair. A new **Landsraad** tab lets you set any player's contribution to any Great House to an arbitrary amount (faction + guild totals recomputed automatically), and water containers get an inline editor to set their stored water.",
  },
  {
    id: "give-package",
    title: "Give Package",
    img: "give-package.png",
    body: "New in v12.0.19 — build and reuse your own item packages. Create named bundles of any items (each with a quantity and tier Mk1–Mk6), then hand a whole package to any player in one click from their Inventory section. Packages are created, edited, and deleted right from the form and saved server-side (item-packages.json), so they persist across restarts and are shared between the desktop app and the remote portal. Delivery uses the normal give-items path, so it works online or offline as long as there's inventory space.",
  },
  {
    id: "give-vehicle-kit",
    title: "Give Vehicle Kit",
    img: "give-vehicle-kit.png",
    body: "Hand a player a whole vehicle without a live RMQ spawn. Pick one of the six CHOAM vehicles with craftable part items (Sandbike, Buggy, Sandcrawler, and Light/Medium/Transport Ornithopters) and DST delivers its full Mk6 part set — chassis, engine, PSU, hull, locomotion, boost — plus a Large Vehicle Fuel Cell and a Welding Torch Mk5, along with each vehicle's named top-tier modules (Mohandis engine, Night Rider boost, ornithopter storage). v12.2.1 corrected the kit contents and added per-part quantities so every vehicle actually assembles: Sandbike Tread ×3, Buggy Tread ×4 plus the Focused Buggy Cutteray Mk6, Sandcrawler's Dampened Treads ×2, and the named Albatross ×4 / Hummingbird ×6 / Roc ×8 ornithopter wing modules (the Carrier also gets Tail Hull ×2 and Side Hull ×2). A new **Allow overflow (drop to ground)** toggle lets a give through even when the player's backpack is full — the game drops whatever doesn't fit next to them. The form previews the exact parts before you hand them over, and it works online or offline as long as there's inventory space.",
  },
  {
    id: "cheat-scripts",
    title: "Cheat Scripts (Players → Live)",
    img: "gameplay-cheat-scripts.png",
    body: "New in v12.2.1 — one-click buttons fire the named server cheat scripts for an online player: Playtest Setup, Award Player XP, Unlock All Skills / Abilities, and Leave Me Alone, plus a freeform box for any other script name. Developer performance harnesses (Start / Stop Hitch Test) sit on a separate Dev / Perf Scripts row. Both carry a disclaimer that the scripts originate from the Playtest server and may have no effect on a retail server.",
  },
  {
    id: "landsraad",
    title: "Players → Landsraad",
    img: "gameplay-landsraad.png",
    body: "Set any player's contribution to any Great House to an arbitrary amount, term by term — faction and guild totals recompute automatically. On the Game Config side, Landsraad edits seed and preserve Funcom's full nested settings struct: v12.2.1 fixed a bug where editing a single Landsraad value could strip the board layouts, messages, and contract settings the game needs, heals stripped struct boxes written by older builds, and warns when your client's copy of the block is incomplete.",
  },
  {
    id: "database",
    title: "Database",
    img: "database.png",
    body: "Take and restore battlegroup Postgres backups without remembering pod names. Schedule recurring cron-based backups straight from the UI with optional pruning of older dumps. A Monaco-powered SQL editor with read-only-by-default toggle and Ctrl+Enter to run.",
  },
  {
    id: "settings",
    title: "Settings",
    img: "settings.png",
    body: "Everything the setup wizard asked you, editable any time. Steam path and SSH-key pickers, Windows username, port-check provider selection, Appearance themes, Remote Access, and the DST auto-updater.",
  },
];
---

<Base
  title="Features — DST"
  description="A page-by-page tour of the Dune Server Tool portal."
>
  <PageHeader
    eyebrow="Tour"
    title="Every page, one tour"
    intro="DST is a left-nav portal grouped under Server Health, PowerShell, Game Data, Database, and System. Here's what each page does."
  />

  <section class="mx-auto max-w-6xl px-6 pb-20 space-y-20">
    {
      sections.map((s, i) => (
        <div
          id={s.id}
          class={`grid md:grid-cols-2 gap-8 items-center ${i % 2 ? "md:[&>:first-child]:order-2" : ""}`}
        >
          <Screenshot src={`${base}screenshots/${s.img}`} alt={s.title} />
          <div>
            <h2 class="text-2xl font-semibold text-dune-text mb-3">
              {s.title}
            </h2>
            <p class="text-dune-muted leading-relaxed">{s.body}</p>
          </div>
        </div>
      ))
    }
  </section>
</Base>
