---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import Screenshot from "../components/Screenshot.astro";

const base = import.meta.env.BASE_URL;

const sections = [
  {
    id: "health",
    title: "Server Health",
    img: "server-health.png",
    body: "Default landing page. Combined battlegroup + VM state, live TCP port verdicts, per-pod game-server status, active spice-field counts pulled live from Postgres with tiered colours and at-cap highlighting, public port checks with provider fallback, and one-click log exports. BG state reads a green 'Healthy' while the operator is healthy or reconciling (its normal steady state), with a per-visit toggle to reveal the raw battlegroup status output.",
  },
  {
    id: "commands",
    title: "Commands",
    img: "commands.png",
    body: "Quick-action cards grouped by VM, Battlegroup, and Tools. Each card knows whether it runs in-app or in a popup, self-disables with a hint when it doesn't apply, and is drag-reorderable — the layout persists across launches.",
  },
  {
    id: "gameconfig",
    title: "Game Config (BETA)",
    img: "game-config.png",
    body: "Grouped editor for UserGame.ini and UserEngine.ini with every setting labelled and typed. Scans the live INIs on load, shows Funcom defaults until you override them, and writes your changes into a DST-managed block — backing up the original on the server before every write. An *All default settings* browser reads the live DefaultGame.ini / DefaultEngine.ini straight from the battlegroup so every Funcom key is searchable and editable, not just the curated set. A risk-acknowledgement modal greets first-time visitors (and re-prompts after every DST update) so a bad edit isn't a silent footgun. One-click Backup settings and View backups buttons keep a restore point a click away.",
  },
  {
    id: "gameplay",
    title: "Gameplay Admin",
    img: "gameplay-admin.png",
    body: "the Gameplay Admin portal, rebuilt natively inside DST as a complete in-tree port (54 player-management endpoints, RMQ-backed online command channel, 28-action bucketed Actions panel). Market / Exchange and Market Bot tabs read your live game Postgres directly (and fall back to a realistic demo dataset when the battlegroup is offline). Duke — the native bot — both buys player listings and lists its own NPC stock with sane-pricing rules (tier × category × rarity × vendor × grade, 100,000 Solari hard cap, per-template overrides), and **Seed market** bulk-lists every catalogued template across all six quality grades in one shot. A safety net detects leftover listings from any prior bot (e.g. Revy from the old Go market-bot) and offers a one-click wipe before Duke starts ticking. The Players tab adds a Hide GM toggle, an inlined Items action group inside Inventory, and three ways to deselect a player — Bases, Storage, and Blueprints round out the toolset. A shared admin-messaging surface (server broadcast, timed shutdown notice, and per-player whisper) sits at the top of the Gameplay overview and on its own Broadcasts page, inventory rows show live current / max durability colour-tiered by wear, and a Restore Destroyed Items action brings completely-dead gear back from zero durability alongside the regular Repair.",
  },
  {
    id: "give-package",
    title: "Give Package",
    img: "give-package.png",
    body: "New in v12.0.19 — build and reuse your own item packages. Create named bundles of any items (each with a quantity and tier Mk1–Mk6), then hand a whole package to any player in one click from their Inventory section. Packages are created, edited, and deleted right from the form and saved server-side (item-packages.json), so they persist across restarts and are shared between the desktop app and the remote portal. Delivery uses the normal give-items path, so it works online or offline as long as there's inventory space.",
  },
  {
    id: "give-vehicle-kit",
    title: "Give Vehicle Kit",
    img: "give-vehicle-kit.png",
    body: "New in v12.0.19 — hand a player a whole vehicle without a live RMQ spawn. Pick one of the six CHOAM vehicles with craftable part items (Sandbike, Buggy, Sandcrawler, and Light/Medium/Transport Ornithopters) and DST delivers its full Mk6 part set — chassis, engine, PSU, hull, locomotion, boost — plus 1 Large Vehicle Fuel Cell and 1 Welding Torch Mk5 straight into the player's inventory. Each kit also includes the vehicle's named/unique top-tier modules (Mohandis engine, Night Rider boost, Albatross/Hummingbird/Roc wings) and the Scout Ornithopter Storage Mk4 (Light) / Assault Ornithopter Storage Mk5 (Medium). The form previews the exact parts before you hand them over, and it works online or offline as long as there's inventory space.",
  },
  {
    id: "database",
    title: "Database",
    img: "database.png",
    body: "Take and restore battlegroup Postgres backups without remembering pod names. Schedule recurring cron-based backups straight from the UI with optional pruning of older dumps. A Monaco-powered SQL editor with read-only-by-default toggle and Ctrl+Enter to run.",
  },
  {
    id: "settings",
    title: "Settings",
    img: "settings.png",
    body: "Everything the setup wizard asked you, editable any time. Steam path and SSH-key pickers, Windows username, port-check provider selection, Appearance themes, Remote Access, and the DST auto-updater.",
  },
];
---

<Base
  title="Features — DST"
  description="A page-by-page tour of the Dune Server Tool portal."
>
  <PageHeader
    eyebrow="Tour"
    title="Every page, one tour"
    intro="DST is a left-nav portal grouped under Server Health, PowerShell, Game Data, Database, and System. Here's what each page does."
  />

  <section class="mx-auto max-w-6xl px-6 pb-20 space-y-20">
    {
      sections.map((s, i) => (
        <div
          id={s.id}
          class={`grid md:grid-cols-2 gap-8 items-center ${i % 2 ? "md:[&>:first-child]:order-2" : ""}`}
        >
          <Screenshot src={`${base}screenshots/${s.img}`} alt={s.title} />
          <div>
            <h2 class="text-2xl font-semibold text-dune-text mb-3">
              {s.title}
            </h2>
            <p class="text-dune-muted leading-relaxed">{s.body}</p>
          </div>
        </div>
      ))
    }
  </section>
</Base>
