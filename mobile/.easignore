# Files EAS Build should NOT upload in the project archive. Keeps the upload small
# and fast (the build server runs a clean install anyway).
node_modules/
.expo/
dist/
web-build/
*.log

# Native build outputs (regenerated by prebuild on EAS)
ios/
android/

# Local/editor cruft
.git/
.vscode/
.idea/
.DS_Store
